{
  "name": "dialoglingo",
  "private": true,
  "version": "0.1.0",
  "description": "Turn local agent chat sessions into English learning material.",
  "license": "MIT",
  "author": "wufei-png",
  "homepage": "https://github.com/wufei-png/dialoglingo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wufei-png/dialoglingo.git"
  },
  "type": "module",
  "main": "dist-electron/main/index.js",
  "engines": {
    "node": "24.15.0"
  },
  "scripts": {
    "rebuild:native:node": "npm rebuild better-sqlite3",
    "capture:native:node": "node scripts/capture-node-better-sqlite3.mjs",
    "prepare:native:electron": "node scripts/prepare-electron-better-sqlite3.mjs",
    "dev": "npm run prepare:native:electron && node scripts/run-electron-vite-dev.mjs",
    "dev:debug": "npm run prepare:native:electron && node scripts/run-electron-vite-dev.mjs --debug",
    "dev:mock-llm": "npm run prepare:native:electron && node scripts/run-electron-vite-dev.mjs --mock-llm",
    "build": "npm run prepare:native:electron && electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "npm run rebuild:native:node && npm run capture:native:node",
    "ci:verify": "npm run typecheck && npm test && npm run build",
    "generate:icons": "node scripts/generate-icons.mjs",
    "verify:package-inputs": "node scripts/verify-package-inputs.mjs",
    "package": "npm run build && npm run verify:package-inputs && electron-builder --publish never",
    "package:mac": "npm run build && npm run verify:package-inputs && electron-builder --mac dmg zip --publish never",
    "package:win": "npm run build && npm run verify:package-inputs && electron-builder --win nsis --publish never",
    "package:linux": "npm run build && npm run verify:package-inputs && electron-builder --linux AppImage deb --publish never",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/main/db/migrate.ts"
  },
  "dependencies": {
    "@paperclipsapp/anki-apkg-export": "^5.0.0",
    "@tanstack/react-query": "^5.81.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.12",
    "@trpc/client": "^10.45.2",
    "@trpc/server": "^10.45.2",
    "better-sqlite3": "12.10.1",
    "drizzle-orm": "^0.45.2",
    "electron-trpc": "0.7.1",
    "i18next": "^26.3.1",
    "motion": "^12.23.12",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.8",
    "zod": "^3.25.76",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@electron/rebuild": "4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "24.13.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.7.0",
    "drizzle-kit": "^0.31.4",
    "electron": "41.7.2",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^2.1.9"
  }
}
